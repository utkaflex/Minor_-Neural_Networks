    "import random\n",
    "import numpy as np\n",
    "import torch\n",
    "import time\n",
    "import torch.nn as nn\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def trainGRU(rnn2, training_data, test_data, n_epoch=10, n_batch_size=128, report_every=1, learning_rate=0.01, criterion = nn.NLLLoss()):\n",
    "    current_loss_train = 0\n",
    "    current_loss_test = 0\n",
    "    all_losses_train = []\n",
    "    all_losses_test = []\n",
    "    \n",
