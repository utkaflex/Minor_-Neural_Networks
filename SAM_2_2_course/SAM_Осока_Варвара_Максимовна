    "    optimizer = torch.optim.Adam(rnn2.parameters(), lr=learning_rate)\n",
    "\n",
    "    start = time.time()\n",
    "    print(f\"Обучаем с количеством сэмплов n = {len(training_data)}\")\n",
    "\n",
    "    for iter in range(1, n_epoch + 1):\n",
    "        current_loss_train = 0\n",
    "        current_loss_test = 0\n",
    "        batches = list(range(len(training_data)))\n",
    "        random.shuffle(batches)\n",
    "        batches = np.array_split(batches, len(batches) // n_batch_size)\n",
    "\n",
    "        for idx, batch in enumerate(batches):\n",
    "            batch_loss_train = 0\n",
    "            for i in batch:\n",
    "                (label_tensor, text_tensor, label, text) = training_data[i]\n",
    "                output, _ = rnn2(text_tensor)\n",
    "                loss = criterion(output, label_tensor)\n",
    "                batch_loss_train += loss / len(batch)\n",
    "\n",
    "            batch_loss_train.backward()\n",
    "            nn.utils.clip_grad_norm_(rnn2.parameters(), 5)\n",
    "            optimizer.step()\n",
    "            optimizer.zero_grad()\n",
    "\n",
    "            current_loss_train += batch_loss_train.item()\n",
    "\n",
    "        all_losses_train.append(current_loss_train / len(batches))\n",
    "\n",
    "        rnn2.eval()\n",
    "        current_loss_test = 0\n",
    "        with torch.no_grad():\n",
    "            for i in range(len(test_data)):\n",
    "                (label_tensor, text_tensor, label, text) = test_data[i]\n",
    "                output, _ = rnn2(text_tensor)\n",
    "                loss = criterion(output, label_tensor)\n",
    "                current_loss_test += loss.item()\n",
